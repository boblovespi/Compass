{
	"schemaVersion": 1,
	"id": "bob-compass",
	"version": "${version}",
	"name": "Compass",
	"description": "Shows a compass bar and some waypoints.",
	"authors": [
		"boblovespi"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "to be determined",
	"icon": "assets/bob-compass/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"boblovespi.compass.Compass"
		],
		"client": [
			"boblovespi.compass.client.CompassClient"
		]
	},
	"mixins": [
		"bob-compass.mixins.json",
		{
			"config": "bob-compass.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.4",
		"java": ">=17",
		"fabric-api": "*"
