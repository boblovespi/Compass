{
	"schemaVersion": 1,
	"id": "bob-compass",
	"version": "${version}",
	"name": "Compass",
	"description": "Shows a compass bar and some waypoints.",
	"authors": [
		"boblovespi"
	],
	"contact": {
		"homepage": "https://github.com/boblovespi/Compass",
		"sources": "https://github.com/boblovespi/Compass",
		"issues": "https://github.com/boblovespi/Compass/issues"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/bob-compass/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"boblovespi.compass.client.CompassClient"
		],
		"modmenu": [
			"boblovespi.compass.client.ModMenuHandler"
		]
	},
	"mixins": [
		"bob-compass.mixins.json",
		{
			"config": "bob-compass.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.4",
		"java": ">=17",
		"fabric-api": "*",
		"yet_another_config_lib_v3": ">=${yacl_version}"
	}
}